---
import '@styles/video.css'
---
 
<div class="video-wrapper">
  <!-- No src here: assigned by JS after page load to prevent blocking window.load -->
  <video class="video-cover" preload="none" autoplay loop playsinline muted></video>
  <div class="fade-overlay top"></div>
  <div class="fade-overlay bottom"></div>
</div>

<script>
  const heroVideo = document.querySelector('.video-cover') as HTMLVideoElement;
  if (heroVideo) {
    const startVideo = () => {
      heroVideo.src = '/videos/v_thumb_nightfall.mp4';
      heroVideo.load();
      heroVideo.play().catch(() => {});
    };

    if (document.readyState === 'complete') {
      startVideo();
    } else {
      window.addEventListener('load', startVideo, { once: true });
      // Fallback: start video after 3s regardless, in case window.load is delayed
      setTimeout(() => {
        if (!heroVideo.src) startVideo();
      }, 3000);
    }
  }
</script>
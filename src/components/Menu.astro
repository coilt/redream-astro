---
import "@styles/menu.css";
import "@styles/nav.button.css";
---

<nav>
  <div class="header-wrapper backdrop-blur-xl">
    <div class="logo">
      <a href="/">
        <img src="/images/logo.svg" fetchpriority="high" />
      </a>
    </div>

    <div id="nav-button">
      <span></span>
      <span></span>
    </div>
  </div>

  <div class="menu-overlay"></div>
  <div class="menu-items-container">
    <ul class="menu-list">
      <li>
        <a href="/" class="menu-item-link">
          <div class="menu-item-wrapper">
            <span class="original-item">Home</span>
            <span class="hover-item">Home</span>
          </div>
        </a>
      </li>
      <li>
        <a href="/films" class="menu-item-link">
          <div class="menu-item-wrapper">
            <span class="original-item">Films</span>
            <span class="hover-item">Films</span>
          </div>
        </a>
      </li>
      <li>
        <a href="/about" class="menu-item-link">
          <div class="menu-item-wrapper">
            <span class="original-item">About</span>
            <span class="hover-item">About</span>
          </div>
        </a>
      </li>
      <li>
        <a href="/contact" class="menu-item-link">
          <div class="menu-item-wrapper">
            <span class="original-item">Contact</span>
            <span class="hover-item">Contact</span>
          </div>
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  function initMenuButton() {
    const navButton = document.getElementById("nav-button");
    const menuList = document.querySelector(".menu-list");
    const menuOverlay = document.querySelector(".menu-overlay");

    if (!navButton || !menuList || !menuOverlay) {
      setTimeout(initMenuButton, 50);
      return;
    }

    navButton.addEventListener("click", () => {
      navButton.classList.toggle("open");
      menuList.classList.toggle("active");
      menuOverlay.classList.toggle("active");
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMenuButton);
  } else {
    initMenuButton();
  }
</script>
